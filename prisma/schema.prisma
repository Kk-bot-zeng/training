generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  employees Employee[]
}

model Employee {
  id           Int          @id @default(autoincrement())
  name         String
  employeeNo   String       @unique
  departmentId Int
  department   Department   @relation(fields: [departmentId], references: [id])
  status       String       @default("active")
  phone        String?
  createdAt    DateTime     @default(now())
  attendance   Attendance[]
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Training {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  type          String       @default("training")
  date          DateTime
  startTime     String
  endTime       String
  location      String?
  departmentIds String
  qrToken       String       @unique
  status        String       @default("upcoming")
  createdAt     DateTime     @default(now())
  attendance    Attendance[]
}

model Attendance {
  id          Int       @id @default(autoincrement())
  trainingId  Int
  training    Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  status      String    @default("present")
  checkInTime DateTime?
  remark      String?
  createdAt   DateTime  @default(now())

  @@unique([trainingId, employeeId])
}

model TrainingRecord {
  id               Int      @id @default(autoincrement())
  topic            String                            // 培训主题
  target           String                            // 培训对象（部门/人员）
  date             DateTime                          // 培训时间
  initiator        String                            // 需求发起人
  format           String   @default("offline")      // 培训形式: online/offline/hybrid
  participantCount Int      @default(0)              // 参训人数
  instructor       String?                           // 讲师
  description      String?                           // 需求描述
  status           String   @default("completed")    // 需求状态: pending/ongoing/completed
  materials        String?                           // 课件 JSON: [{name, url, type}]
  recording        String?                           // 培训录屏URL
  createdAt        DateTime @default(now())
}
